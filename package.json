{
  "name": "nekonymous",
  "version": "0.1.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.69.0",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "wrangler": "4.100.0"
  },
  "private": true,
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "deploy": "wrangler deploy --minify",
    "cleanup": "node tools/cleanup.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test:crypto": "node --experimental-strip-types tools/verify-crypto.ts",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run knip && pnpm run test:crypto"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "grammy": "^1.43.0"
  }
}
